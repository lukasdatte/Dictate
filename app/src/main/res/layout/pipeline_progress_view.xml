<?xml version="1.0" encoding="utf-8"?>
<!-- Compact pipeline progress view: 2 rows (last done + current running step).
     Embedded inside prompts_keyboard_cl (72dp). Each row ~28dp + padding = fits. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/pipeline_progress_ll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:visibility="gone"
    tools:visibility="visible">

    <!-- Row 1: Last completed step -->
    <LinearLayout
        android:id="@+id/pipeline_row_done"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/pipeline_done_icon_tv"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:textSize="14sp"
            tools:text="✅" />

        <TextView
            android:id="@+id/pipeline_done_name_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="13sp"
            tools:text="Transkription" />

        <TextView
            android:id="@+id/pipeline_done_duration_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="1.8s" />
    </LinearLayout>

    <!-- Row 2: Currently running step + cancel button -->
    <LinearLayout
        android:id="@+id/pipeline_row_running"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <ProgressBar
            android:id="@+id/pipeline_running_pb"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="3dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/pipeline_running_name_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="11dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="13sp"
            tools:text="Formatierung" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pipeline_cancel_btn"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/dictate_cancel"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
